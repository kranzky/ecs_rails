<% content_for :title, "Posts" %>

<div class="page-head page-head--row">
  <div>
    <h1>Bulletin</h1>
    <p>Published posts, newest first.</p>
  </div>
  <%= link_to "New post", new_post_path, class: "btn btn--primary" %>
</div>

<% if @posts.empty? %>
  <div class="empty">
    <p>No published posts yet.</p>
    <%= link_to "Write the first one", new_post_path, class: "btn btn--primary" %>
  </div>
<% else %>
  <div class="stack">
    <% @posts.each do |post| %>
      <article class="card card-link post-card">
        <%= link_to post do %>
          <h2><%= post.title.text %></h2>
        <% end %>
        <p class="post-card__excerpt"><%= truncate(post.body.text.to_s, length: 140) %></p>
        <div class="meta" style="margin-top:.85rem">
          <%= byline post.author %>
          <span class="dot"></span>
          <span class="count">♥ <%= likes_count(post) %></span>
          <span class="dot"></span>
          <%= time_ago_in_words(post.created_at) %> ago
        </div>
      </article>
    <% end %>
  </div>
<% end %>
